<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Financial Workflow Bot</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <!-- Header -->
        <header class="header">
            <h1>💰 Financial Workflow Bot</h1>
            <p class="demo-badge">⚠️ SIMULATED DEMO - NO REAL TRANSACTIONS</p>
        </header>

        <!-- Dashboard Stats -->
        <section class="dashboard">
            <div class="stat-card">
                <h3>Running Total</h3>
                <p class="amount" id="runningTotal">$0.00</p>
            </div>
            <div class="stat-card">
                <h3>Total Transactions</h3>
                <p class="count" id="transactionCount">0</p>
            </div>
            <div class="stat-card">
                <h3>Status</h3>
                <p class="status" id="statusIndicator">Ready</p>
            </div>
        </section>

        <!-- Add Income Form -->
        <section class="form-section">
            <h2>Add Income Source</h2>
            <form id="incomeForm">
                <div class="form-group">
                    <label for="sourceLink">Source Link:</label>
                    <input type="text" id="sourceLink" placeholder="https://example.com/payment" required>
                </div>

                <div class="form-group">
                    <label for="incomeSource">Income Source:</label>
                    <input type="text" id="incomeSource" placeholder="e.g., Freelance Project, Salary, Investment" required>
                </div>

                <div class="form-group">
                    <label for="amountReceived">Amount Received:</label>
                    <input type="number" id="amountReceived" placeholder="0.00" step="0.01" min="0" required>
                </div>

                <div class="form-group">
                    <label for="dateReceived">Date Received:</label>
                    <input type="date" id="dateReceived" required>
                </div>

                <div class="form-group">
                    <label for="description">Description:</label>
                    <textarea id="description" placeholder="Add notes about this transaction..." rows="3"></textarea>
                </div>

                <button type="submit" class="btn btn-primary">➕ Add Income</button>
            </form>
        </section>

        <!-- Transactions Table -->
        <section class="transactions-section">
            <h2>Transaction History</h2>
            <div class="table-container">
                <table class="transactions-table">
                    <thead>
                        <tr>
                            <th>Source Link</th>
                            <th>Income Source</th>
                            <th>Amount</th>
                            <th>Date</th>
                            <th>Running Total</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="transactionsBody">
                        <!-- Transactions will be added here -->
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Notifications -->
        <section class="notifications-section">
            <h2>Recent Notifications</h2>
            <div id="notificationsContainer" class="notifications-container">
                <!-- Notifications will appear here -->
            </div>
        </section>

        <!-- Action Buttons -->
        <section class="actions-section">
            <button class="btn btn-secondary" onclick="exportData()">📥 Export Data</button>
            <button class="btn btn-secondary" onclick="clearAllData()">🗑️ Clear All Data</button>
            <button class="btn btn-secondary" onclick="loadSampleData()">📊 Load Sample Data</button>
        </section>
    </div>

    <!-- Notification Toast -->
    <div id="notificationToast" class="notification-toast"></div>

    <script src="script.js"></script>
</body>
</html>
