// Load initial welcome notification
function loadInitialNotification() {
    if (notifications.length === 0) {
        const welcomeNotif = {
            id: Date.now(),
            type: 'info',
            icon: '👋',
            title: 'Welcome to Financial Workflow Bot',
            message: 'This is a simulated financial tracking system for demonstration purposes',
            details: '⚠️ All data is LOCAL and SIMULATED. No real transactions or banking connections.',
            time: new Date().toLocaleString()
        };

        notifications.push(welcomeNotif);
        localStorage.setItem('notifications', JSON.stringify(notifications));
        renderNotifications();
    }
}

// Utility functions
function truncateUrl(url, length = 40) {
    return url.length > length ? url.substring(0, length) + '...' : url;
}

function formatDate(dateString) {
    const options = { year: 'numeric', month: 'short', day: 'numeric' };
    return new Date(dateString).toLocaleDateString(undefined, options);
}